# Ignore heavy regeneration inputs; commit compact evidence and canonical figures.
references/**
!references/.gitkeep
!references/refs.yaml
data/**
!data/.gitkeep
!data/evidence/
!data/evidence/**
!data/showcase.json
!data/winner.json
figures/**
!figures/README.md
!figures/index.html
!figures/manifest.json
!figures/*/
!figures/*/*.html
!figures/*/*.js
!figures/*/*.png

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.env
.DS_Store
.idea/
.vscode/
.claude/

# run logs (regeneration helper output)
logs/**
!logs/.gitkeep
