# Generated research inputs and run products are local, reproducible artifacts.
references/**
!references/.gitkeep
!references/refs.yaml
data/**
!data/.gitkeep
!data/evidence/
data/evidence/**
!data/evidence/.gitkeep
figures/
tmp/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.env
.DS_Store
.idea/
.vscode/
.claude/

# run logs (regeneration helper output)
logs/**
!logs/.gitkeep
